{"identifier":{"url":"doc:\/\/TMDB\/documentation\/TMDB\/Usage","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Article","modules":[{"name":"TMDB"}],"role":"article","title":"Usage"},"variants":[{"paths":["\/documentation\/tmdb\/usage"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"abstract":[{"type":"text","text":"Instructions on initialization and usage of the "},{"type":"codeVoice","code":"swift-tmdb"},{"type":"text","text":" package."}],"kind":"article","seeAlsoSections":[{"generated":true,"anchor":"Getting-Started","identifiers":["doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide","doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews","doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists","doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","doc:\/\/TMDB\/documentation\/TMDB\/TMDB","doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration"],"title":"Getting Started"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Requirements","text":"Requirements"},{"inlineContent":[{"type":"codeVoice","code":"swift-tmdb"},{"type":"text","text":" requires a TMDB API Key in order to function."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Follow their "},{"identifier":"https:\/\/developer.themoviedb.org\/docs\/getting-started","type":"reference","isActive":true},{"type":"text","text":" guide in order to get your key."}],"type":"paragraph"},{"style":"warning","type":"aside","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/nshipster.com\/secrets\/","type":"reference"},{"text":" with your TMDB API Key and do not store it inside of your source code repository.","type":"text"}]}]},{"type":"heading","level":2,"anchor":"Initializing","text":"Initializing"},{"inlineContent":[{"type":"text","text":"Initialize the TMDB client with your TMDB API Key. This only needs to be done once, and it’d be best to do it as early"},{"type":"text","text":" "},{"type":"text","text":"in your app’s lifecycle as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if you’re using the SwiftUI app lifecycle:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import SwiftUI","import TMDB","","@main","struct MyApp: App {","    init() {","        initializeTMDB()","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","","    private func initializeTMDB() {","        Task {","            do {","                try await TMDB.initialize(apiKey: \"APIKEYHERE\")","            } catch {","                print(\"Unable to initialize\", error)","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"For more control, use "},{"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration","type":"reference","isActive":true},{"type":"text","text":" directly:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let config = TMDBConfiguration(","    apiKey: \"APIKEYHERE\",","    defaultLanguage: Locale(identifier: \"en-US\"),","    defaultRegion: Locale.Region(\"US\")",")","try await TMDB.initialize(configuration: config)"]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"defaultLanguage"},{"type":"text","text":" and "},{"type":"codeVoice","code":"defaultRegion"},{"type":"text","text":" values are injected automatically into endpoints that support them. Per-request overrides always take precedence."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Getting-Data","text":"Getting Data"},{"inlineContent":[{"type":"text","text":"After initialization, there are two ways to use the module to request data from the TMDB API."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Using-Static-Methods","text":"Using Static Methods"},{"inlineContent":[{"type":"text","text":"Call static methods directly on the "},{"type":"codeVoice","code":"TMDB"},{"type":"text","text":" enum. Here’s an example fetching movie details:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import SwiftUI","import TMDB","","struct MovieDetails: View {","    @State private var movie: TMDB.Movie?","","    var body: some View {","        VStack {","            if let movie {","                Text(movie.title)","                    .font(.title)","                Text(movie.runtime, format: .runtime)","            } else {","                Text(\"Loading movie details\")","                ProgressView()","            }","        }","        .padding()","        .task {","            do {","                let movie = try await TMDB.movieDetails(id: 278)","                withAnimation {","                    self.movie = movie","                }","            } catch {","                print(error)","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"The same pattern works across all endpoint categories — movies, TV series, seasons, episodes, search, discover, trending, and more:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ TV series","let series = try await TMDB.tvSeriesDetails(id: 1396)","","\/\/ Search","let results = try await TMDB.searchMovies(query: \"Inception\")","","\/\/ Trending","let trending = try await TMDB.trendingAll(timeWindow: .week)","","\/\/ Discover with filters","let action = try await TMDB.discoverMovie(filters: .withGenres([.and(\"28\")]), .sortBy(.popularity, .descending))"]},{"inlineContent":[{"type":"text","text":"Calling these methods is safe from SwiftUI Previews and unit tests. "},{"type":"codeVoice","code":"swift-tmdb"},{"type":"text","text":" uses "},{"identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","type":"reference","isActive":true},{"type":"text","text":" to provide mock data automatically."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Image-URLs","text":"Image URLs"},{"inlineContent":[{"type":"text","text":"Image configuration is auto-fetched and cached during "},{"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(configuration:)","type":"reference","isActive":true},{"type":"text","text":" (or "},{"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(apiKey:urlSessionConfiguration:)","type":"reference","isActive":true},{"type":"text","text":"). Response types that include image paths provide convenience methods to construct full image URLs without any manual configuration fetch:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let movie = try await TMDB.movieDetails(id: 550)","","\/\/ Construct a poster URL","if let posterURL = try movie.posterImageURL(size: .setWidth(500)) {","    \/\/ Use posterURL to load the image","}","","\/\/ Construct a backdrop URL","if let backdropURL = try movie.backdropImageURL(size: .setWidth(780)) {","    \/\/ Use backdropURL to load the image","}"]},{"inlineContent":[{"type":"text","text":"To inspect which image sizes are available, use "},{"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/imageConfiguration-swift.type.property","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["if let config = TMDB.imageConfiguration {","    print(config.posterSizes)   \/\/ e.g., [w92, w154, w185, w342, w500, w780, original]","    print(config.backdropSizes) \/\/ e.g., [w300, w780, w1280, original]","}"]},{"inlineContent":[{"type":"text","text":"The cached "},{"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/changeKeys","type":"reference","isActive":true},{"type":"text","text":" array is also available after initialization."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Optional-Using-Dependency-Clients