{"abstract":[{"text":"Instructions on initialization and usage of the ","type":"text"},{"code":"swift-tmdb","type":"codeVoice"},{"text":" package.","type":"text"}],"metadata":{"title":"Usage","modules":[{"name":"TMDB"}],"roleHeading":"Article","role":"article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/TMDB\/documentation\/TMDB\/Usage"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/tmdb\/usage"]}],"seeAlsoSections":[{"generated":true,"anchor":"Getting-Started","title":"Getting Started","identifiers":["doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide","doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews","doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists","doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","doc:\/\/TMDB\/documentation\/TMDB\/TMDB","doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Requirements","type":"heading","level":2,"text":"Requirements"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"swift-tmdb"},{"type":"text","text":" requires a TMDB API Key in order to function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow their "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.themoviedb.org\/docs\/getting-started"},{"type":"text","text":" guide in order to get your key."}]},{"style":"warning","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/nshipster.com\/secrets\/","type":"reference"},{"text":" with your TMDB API Key and do not store it inside of your source code repository.","type":"text"}],"type":"paragraph"}],"name":"Warning","type":"aside"},{"text":"Initializing","anchor":"Initializing","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Initialize the TMDB client with your TMDB API Key. This only needs to be done once, and it’d be best to do it as early","type":"text"},{"text":" ","type":"text"},{"text":"in your app’s lifecycle as possible.","type":"text"}]},{"inlineContent":[{"text":"For example, if you’re using the SwiftUI app lifecycle:","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import TMDB","","@main","struct MyApp: App {","    init() {","        initializeTMDB()","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","","    private func initializeTMDB() {","        Task {","            do {","                try await TMDB.initialize(apiKey: \"APIKEYHERE\")","            } catch {","                print(\"Unable to initialize\", error)","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"For more control, use "},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration","isActive":true},{"type":"text","text":" directly:"}],"type":"paragraph"},{"code":["let config = TMDBConfiguration(","    apiKey: \"APIKEYHERE\",","    defaultLanguage: Locale(identifier: \"en-US\"),","    defaultRegion: Locale.Region(\"US\")",")","try await TMDB.initialize(configuration: config)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"defaultLanguage","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"defaultRegion","type":"codeVoice"},{"text":" values are injected automatically into endpoints that support them. Per-request overrides always take precedence.","type":"text"}]},{"text":"Getting Data","anchor":"Getting-Data","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After initialization, there are two ways to use the module to request data from the TMDB API."}]},{"anchor":"Using-Static-Methods","text":"Using Static Methods","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call static methods directly on the "},{"type":"codeVoice","code":"TMDB"},{"type":"text","text":" enum. Here’s an example fetching movie details:"}]},{"syntax":"swift","code":["import SwiftUI","import TMDB","","struct MovieDetails: View {","    @State private var movie: TMDB.Movie?","","    var body: some View {","        VStack {","            if let movie {","                Text(movie.title)","                    .font(.title)","                Text(movie.runtime, format: .runtime)","            } else {","                Text(\"Loading movie details\")","                ProgressView()","            }","        }","        .padding()","        .task {","            do {","                let movie = try await TMDB.movieDetails(id: 278)","                withAnimation {","                    self.movie = movie","                }","            } catch {","                print(error)","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same pattern works across all endpoint categories — movies, TV series, seasons, episodes, search, discover, trending, and more:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ TV series","let series = try await TMDB.tvSeriesDetails(id: 1396)","","\/\/ Search","let results = try await TMDB.searchMovies(query: \"Inception\")","","\/\/ Trending","let trending = try await TMDB.trendingAll(timeWindow: .week)","","\/\/ Discover with filters","let action = try await TMDB.discoverMovie(filters: .withGenres([.and(\"28\")]), .sortBy(.popularity, .descending))"]},{"inlineContent":[{"text":"Calling these methods is safe from SwiftUI Previews and unit tests. ","type":"text"},{"code":"swift-tmdb","type":"codeVoice"},{"text":" uses ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","type":"reference"},{"text":" to provide mock data automatically.","type":"text"}],"type":"paragraph"},{"anchor":"Image-URLs","type":"heading","level":2,"text":"Image URLs"},{"inlineContent":[{"text":"Image configuration is auto-fetched and cached during ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(configuration:)","type":"reference"},{"text":" (or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(apiKey:urlSessionConfiguration:)","type":"reference"},{"text":"). Response types that include image paths provide convenience methods to construct full image URLs without any manual configuration fetch:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let movie = try await TMDB.movieDetails(id: 550)","","\/\/ Construct a poster URL","if let posterURL = try movie.posterImageURL(size: .setWidth(500)) {","    \/\/ Use posterURL to load the image","}","","\/\/ Construct a backdrop URL","if let backdropURL = try movie.backdropImageURL(size: .setWidth(780)) {","    \/\/ Use backdropURL to load the image","}"]},{"inlineContent":[{"text":"To inspect which image sizes are available, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/imageConfiguration-swift.type.property","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["if let config = TMDB.imageConfiguration {","    print(config.posterSizes)   \/\/ e.g., [w92, w154, w185, w342, w500, w780, original]","    print(config.backdropSizes) \/\/ e.g., [w300, w780, w1280, original]","}"]},{"inlineContent":[{"text":"The cached ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/changeKeys","type":"reference"},{"text":" array is also available after initialization.","type":"text"}],"type":"paragraph"},{"anchor":"Optional-Using-Dependency-Cli