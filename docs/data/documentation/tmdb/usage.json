{"primaryContentSections":[{"content":[{"anchor":"Requirements","level":2,"type":"heading","text":"Requirements"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"swift-tmdb"},{"text":" requires a TMDB API Key in order to function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Follow their ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.themoviedb.org\/docs\/getting-started","isActive":true},{"text":" guide in order to get your key.","type":"text"}]},{"style":"warning","name":"Warning","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/nshipster.com\/secrets\/","type":"reference"},{"text":" with your TMDB API Key and do not store it inside of your source code repository.","type":"text"}],"type":"paragraph"}]},{"anchor":"Initializing","level":2,"type":"heading","text":"Initializing"},{"type":"paragraph","inlineContent":[{"text":"Initialize the TMDB client with your TMDB API Key. This only needs to be done once, and it’d be best to do it as early","type":"text"},{"text":" ","type":"text"},{"text":"in your app’s lifecycle as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, if you’re using the SwiftUI app lifecycle:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import TMDB","","@main","struct MyApp: App {","    init() {","        initializeTMDB()","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","","    private func initializeTMDB() {","        Task {","            do {","                try await TMDB.initialize(apiKey: \"APIKEYHERE\")","            } catch {","                print(\"Unable to initialize\", error)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"For more control, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration","isActive":true},{"text":" directly:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let config = TMDBConfiguration(","    apiKey: \"APIKEYHERE\",","    defaultLanguage: Locale(identifier: \"en-US\"),","    defaultRegion: Locale.Region(\"US\")",")","try await TMDB.initialize(configuration: config)"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"defaultLanguage"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"defaultRegion"},{"text":" values are injected automatically into endpoints that support them. Per-request overrides always take precedence.","type":"text"}]},{"anchor":"Getting-Data","level":2,"type":"heading","text":"Getting Data"},{"type":"paragraph","inlineContent":[{"text":"After initialization, there are two ways to use the module to request data from the TMDB API.","type":"text"}]},{"anchor":"Using-Static-Methods","level":3,"type":"heading","text":"Using Static Methods"},{"type":"paragraph","inlineContent":[{"text":"Call static methods directly on the ","type":"text"},{"type":"codeVoice","code":"TMDB"},{"text":" enum. Here’s an example fetching movie details:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import TMDB","","struct MovieDetails: View {","    @State private var movie: TMDB.Movie?","","    var body: some View {","        VStack {","            if let movie {","                Text(movie.title)","                    .font(.title)","                Text(movie.runtime, format: .runtime)","            } else {","                Text(\"Loading movie details\")","                ProgressView()","            }","        }","        .padding()","        .task {","            do {","                let movie = try await TMDB.movieDetails(id: 278)","                withAnimation {","                    self.movie = movie","                }","            } catch {","                print(error)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The same pattern works across all endpoint categories — movies, TV series, seasons, episodes, search, discover, trending, and more:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ TV series","let series = try await TMDB.tvSeriesDetails(id: 1396)","","\/\/ Search","let results = try await TMDB.searchMovies(query: \"Inception\")","","\/\/ Trending","let trending = try await TMDB.trendingAll(timeWindow: .week)","","\/\/ Discover with filters","let action = try await TMDB.discoverMovie(filters: .withGenres([.and(\"28\")]), .sortBy(.popularity, .descending))"]},{"type":"paragraph","inlineContent":[{"text":"Calling these methods is safe from SwiftUI Previews and unit tests. ","type":"text"},{"type":"codeVoice","code":"swift-tmdb"},{"text":" uses ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","isActive":true},{"text":" to provide mock data automatically.","type":"text"}]},{"anchor":"Image-URLs","level":2,"type":"heading","text":"Image URLs"},{"type":"paragraph","inlineContent":[{"text":"Image configuration is auto-fetched and cached during ","type":"text"},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(configuration:)","isActive":true},{"text":" (or ","type":"text"},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/initialize(apiKey:urlSessionConfiguration:)","isActive":true},{"text":"). Response types that include image paths provide convenience methods to construct full image URLs without any manual configuration fetch:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let movie = try await TMDB.movieDetails(id: 550)","","\/\/ Construct a poster URL","if let posterURL = try movie.posterImageURL(size: .setWidth(500)) {","    \/\/ Use posterURL to load the image","}","","\/\/ Construct a backdrop URL","if let backdropURL = try movie.backdropImageURL(size: .setWidth(780)) {","    \/\/ Use backdropURL to load the image","}"]},{"type":"paragraph","inlineContent":[{"text":"To inspect which image sizes are available, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/imageConfiguration-swift.type.property","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if let config = TMDB.imageConfiguration {","    print(config.posterSizes)   \/\/ e.g., [w92, w154, w185, w342, w500, w780, original]","    print(config.backdropSizes) \/\/ e.g., [w300, w780, w1280, original]","}"]},{"type":"paragraph","inlineContent":[{"text":"The cached ","type":"text"},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/changeKeys","isActive":true},{"text":" array is also available after initialization.","type":"text"}]},{"anchor":"Optional-Using-Dependency-Clients","level":3,"type":"heading","text":"(Optional) Using Dependency Clients"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"TMDBDependencies"},{"text":" module provides ","type":"text"},{"type":"codeVoice","code":"@Dependency"},{"text":"-based clients for use with PointFree’s ","type":"text"},{"overridingTitle":"swift-dependencies","overridingTitleInlineContent":[{"text":"swift-dependencies","type":"text"}],"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","isActive":true},{"text":" package.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Available clients:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Client","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Dependency Key","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Endpoints","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"MoviesClient","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"\\.tmdbMovies