{"abstract":[{"text":"Manage favorites, watchlists, ratings, and custom lists for authenticated users.","type":"text"}],"sections":[],"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Getting Started","identifiers":["doc:\/\/TMDB\/documentation\/TMDB\/Usage","doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide","doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews","doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","doc:\/\/TMDB\/documentation\/TMDB\/TMDB","doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration"],"generated":true,"anchor":"Getting-Started"}],"metadata":{"roleHeading":"Article","role":"article","title":"Account and Lists","modules":[{"name":"TMDB"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/tmdb\/accountandlists"]}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"All operations in this article require authentication. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide"},{"type":"text","text":" to set up a user session first."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Favorites and Watchlist","anchor":"Favorites-and-Watchlist"},{"inlineContent":[{"type":"text","text":"Add or remove movies and TV series from a user’s favorites or watchlist using "},{"type":"reference","isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/Account\/MediaType"},{"type":"text","text":" to specify the media kind."}],"type":"paragraph"},{"code":["\/\/ Add a movie to favorites","try await TMDB.setFavorite(mediaType: .movie, mediaID: 550, favorite: true)","","\/\/ Remove a TV series from favorites","try await TMDB.setFavorite(mediaType: .tv, mediaID: 1396, favorite: false)","","\/\/ Add to watchlist","try await TMDB.setWatchlist(mediaType: .movie, mediaID: 550, watchlist: true)"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Ratings","anchor":"Ratings"},{"inlineContent":[{"type":"text","text":"Rate movies and TV on a scale of 0.5 to 10.0 (in 0.5 increments)."}],"type":"paragraph"},{"code":["\/\/ Rate a movie","try await TMDB.rateMovie(id: 550, rating: 8.5)","","\/\/ Delete a rating","try await TMDB.deleteMovieRating(id: 550)","","\/\/ Rate a TV series","try await TMDB.rateTVSeries(id: 1396, rating: 9.0)","","\/\/ Rate a specific episode","try await TMDB.rateTVEpisode(","    seriesID: 1396,","    seasonNumber: 1,","    episodeNumber: 1,","    rating: 9.5",")"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Reading Account Data","anchor":"Reading-Account-Data"},{"inlineContent":[{"type":"text","text":"Fetch paginated lists of a user’s favorites, ratings, watchlist, and recommendations."}],"type":"paragraph"},{"code":["let favorites = try await TMDB.favoriteMovies()","let rated = try await TMDB.ratedMovies()","let watchlist = try await TMDB.watchlistMovies()","let recommendations = try await TMDB.accountMovieRecommendations()","","\/\/ With sorting and pagination","let sortedFavorites = try await TMDB.favoriteMovies(","    sortBy: .createdAtDescending,","    page: 2",")"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Lists","anchor":"Lists"},{"inlineContent":[{"type":"text","text":"Create and manage custom lists using the v4 API."}],"type":"paragraph"},{"code":["\/\/ Create a list","let result = try await TMDB.createList(","    name: \"My Favorites\",","    description: \"A collection of my all-time favorites\"",")","let listID = result.id","","\/\/ Add items (each item is a tuple of media type, ID, and optional comment)","try await TMDB.addItemsToList(listID: listID, items: [","    (mediaType: .movie, mediaID: 550, comment: \"Classic\"),","    (mediaType: .tv, mediaID: 1396, comment: nil),","])","","\/\/ View list details","let details = try await TMDB.listDetails(listID: listID)","","\/\/ Check if an item is in the list","let status = try await TMDB.listItemStatus(","    listID: listID,","    mediaType: .movie,","    mediaID: 550",")","","\/\/ Remove items","try await TMDB.removeItemsFromList(listID: listID, items: [","    (mediaType: .movie, mediaID: 550),","])","","\/\/ Clear all items","try await TMDB.clearList(listID: listID)","","\/\/ Delete the list","try await TMDB.deleteList(listID: listID)"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"Guest Sessions","anchor":"Guest-Sessions"},{"inlineContent":[{"type":"text","text":"Guest sessions allow unauthenticated users to rate content. Ratings are stored temporarily on TMDB’s servers."}],"type":"paragraph"},{"code":["\/\/ Create a guest session","let guestSession = try await TMDB.createGuestSession()","let sessionID = guestSession.guestSessionID","","\/\/ Rate a movie as a guest","try await TMDB.guestRateMovie(","    id: 550,","    rating: 7.5,","    guestSessionID: sessionID",")","","\/\/ Retrieve guest-rated movies","let rated = try await TMDB.guestRatedMovies(sessionID: sessionID)","","\/\/ Delete a guest rating","try await TMDB.guestDeleteMovieRating(id: 550, guestSessionID: sessionID)"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"references":{"doc://TMDB/documentation/TMDB/TMDB/Account/MediaType":{"navigatorTitle":[{"text":"MediaType","kind":"identifier"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MediaType","kind":"identifier"}],"type":"topic","kind":"symbol","abstract":[],"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/Account\/MediaType","title":"TMDB.Account.MediaType","url":"\/documentation\/tmdb\/tmdb\/account\/mediatype"},"doc://TMDB/documentation/TMDB":{"abstract":[{"type":"text","text":"A Swift 6.2 wrapper around the TMDB API. Engineered for simplicity."}],"role":"collection","kind":"symbol","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB","title":"TMDB","url":"\/documentation\/tmdb"},"doc://TMDB/documentation/TMDB/Usage":{"role":"article","type":"topic","kind":"article","abstract":[{"text":"Instructions on initialization and usage of the ","type":"text"},{"type":"codeVoice","code":"swift-tmdb"},{"text":" package.","type":"text"}],"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/Usage","title":"Usage","url":"\/documentation\/tmdb\/usage"},"doc://TMDB/documentation/TMDB/AuthenticationGuide":{"kind":"article","url":"\/documentation\/tmdb\/authenticationguide","abstract":[{"text":"Authenticate users with TMDB to enable account features, lists, and ratings.","type":"text"}],"title":"Authentication","role":"article","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide"},"doc://TMDB/documentation/TMDB/TMDB":{"abstract":[{"text":"The top level namespace for the ","type":"text"},{"code":"swift-tmdb","type":"codeVoice"},{"text":" package","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TMDB","kind":"identifier"}],"role":"symbol","kind":"symbol","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB","title":"TMDB","url":"\/documentation\/tmdb\/tmdb","navigatorTitle":[{"text":"TMDB","kind":"identifier"}]},"doc://TMDB/documentation/TMDB/DiscoverFilters":{"role":"article","type":"topic","kind":"article","abstract":[{"type":"text","text":"Build type-safe, composable queries for the TMDB Discover endpoint."}],"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","title":"Discover Filters","url":"\/documentation\/tmdb\/discoverfilters"},"doc://TMDB/documentation/TMDB/ErrorHandling":{"role":"article","type":"topic","kind":"article","abstract":[{"text":"Handle errors from TMDB API requests using typed throws.","type":"text"}],"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","title":"Error Handling","url":"\/documentation\/tmdb\/errorhandling"},"doc://TMDB/documentation/TMDB/TMDBConfiguration":{"kind":"symbol","url":"\/documentation\/tmdb\/tmdbconfiguration","abstract":[{"text":"A configuration struct used by the package to configure itself.","type":"text"}],"title":"TMDBConfiguration","role":"symbol","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TMDBConfiguration","kind":"identifier"}],"navigatorTitle":[{"text":"TMDBConfiguration","kind":"identifier"}]},"doc://TMDB/documentation/TMDB/TestingAndPreviews":{"kind":"article","url":"\/documentation\/tmdb\/testingandpreviews","abstract":[{"text":"Use automatic mock data in unit tests and SwiftUI previews with zero configuration.","type":"text"}],"title":"Testing and Previews","role":"article","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews"}}}