{"variants":[{"paths":["\/documentation\/tmdb\/authenticationguide"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"sections":[],"abstract":[{"text":"Authenticate users with TMDB to enable account features, lists, and ratings.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"Authentication unlocks account-level features: managing favorites and watchlists, rating movies and TV shows, and creating lists. ","type":"text"},{"code":"swift-tmdb","type":"codeVoice"},{"text":" provides platform-specific helpers for SwiftUI and UIKit, plus a manual flow for custom UIs.","type":"text"}],"type":"paragraph"},{"level":2,"text":"SwiftUI","anchor":"SwiftUI","type":"heading"},{"inlineContent":[{"text":"Import ","type":"text"},{"code":"TMDBSwiftUI","type":"codeVoice"},{"text":" and use the ","type":"text"},{"code":".tmdbAuthentication","type":"codeVoice"},{"text":" view modifier. It presents a browser-based OAuth flow and returns the result.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import TMDBSwiftUI","","struct SettingsView: View {","    @State private var showAuth = false","","    var body: some View {","        Button(\"Sign In with TMDB\") {","            showAuth = true","        }","        .tmdbAuthentication(isPresented: $showAuth) { result in","            switch result {","            case .success(let session):","                print(\"Authenticated: \\(session.accountID)\")","            case .failure(let error):","                print(\"Auth failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing"},{"level":2,"text":"UIKit","anchor":"UIKit","type":"heading"},{"inlineContent":[{"text":"Import ","type":"text"},{"code":"TMDBUIKit","type":"codeVoice"},{"text":" and call ","type":"text"},{"code":"TMDB.authenticate(presentationAnchor:)","type":"codeVoice"},{"text":" from a view controller.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import UIKit","import TMDBUIKit","","class SettingsViewController: UIViewController {","    @IBAction func signInTapped(_ sender: Any) {","        Task {","            do {","                let session = try await TMDB.authenticate(","                    presentationAnchor: view.window!","                )","                print(\"Authenticated: \\(session.accountID)\")","            } catch {","                print(\"Auth failed: \\(error)\")","            }","        }","    }","}"],"type":"codeListing"},{"level":2,"text":"Manual Flow","anchor":"Manual-Flow","type":"heading"},{"inlineContent":[{"text":"For custom UIs, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/AuthenticationCoordinator"},{"text":" directly. This gives you control over each step of the OAuth flow.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let coordinator = TMDB.AuthenticationCoordinator()","","\/\/ Step 1: Create a request token and get the approval URL","let (requestToken, approvalURL) = try await coordinator.createRequestToken()","","\/\/ Step 2: Open approvalURL in a browser for the user to approve","\/\/ When the browser redirects back to your app with a URL...","","\/\/ Step 3: Complete authentication with the redirect URL","let session = try await coordinator.authenticate(browserRedirectURL: redirectURL)","print(\"Access token: \\(session.accessToken)\")","print(\"Account ID: \\(session.accountID)\")"],"type":"codeListing"},{"level":2,"text":"Logout","anchor":"Logout","type":"heading"},{"syntax":"swift","code":["try await TMDB.logout()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This deletes the v4 access token, v3 session, and clears the keychain."}],"type":"paragraph"},{"anchor":"Checking-Auth-State","type":"heading","level":2,"text":"Checking Auth State"},{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/isAuthenticated","type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/currentSession","type":"reference"},{"text":" to check the current state:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["if TMDB.isAuthenticated {","    let session = TMDB.currentSession","    print(\"Logged in as \\(session?.accountID ?? \"\")\")","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/AuthSession","type":"reference"},{"type":"text","text":" struct provides the authenticated user’s credentials:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Property"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessToken"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4 API access token"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"accountID","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String"}]}],[{"type":"paragraph","inlineContent":[{"text":"TMDB account identifier","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"sessionID","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String?"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3 session ID (if converted)"}]}]]]}],"kind":"content"}],"kind":"article","seeAlsoSections":[{"title":"Getting Started","generated":true,"identifiers":["doc:\/\/TMDB\/documentati