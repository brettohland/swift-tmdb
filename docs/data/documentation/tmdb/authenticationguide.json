{"abstract":[{"type":"text","text":"Authenticate users with TMDB to enable account features, lists, and ratings."}],"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide"},"sections":[],"seeAlsoSections":[{"generated":true,"title":"Getting Started","anchor":"Getting-Started","identifiers":["doc:\/\/TMDB\/documentation\/TMDB\/Usage","doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews","doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists","doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","doc:\/\/TMDB\/documentation\/TMDB\/TMDB","doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Authentication unlocks account-level features: managing favorites and watchlists, rating movies and TV shows, and creating lists. ","type":"text"},{"type":"codeVoice","code":"swift-tmdb"},{"text":" provides platform-specific helpers for SwiftUI and UIKit, plus a manual flow for custom UIs.","type":"text"}]},{"type":"heading","anchor":"SwiftUI","level":2,"text":"SwiftUI"},{"type":"paragraph","inlineContent":[{"text":"Import ","type":"text"},{"type":"codeVoice","code":"TMDBSwiftUI"},{"text":" and use the ","type":"text"},{"type":"codeVoice","code":".tmdbAuthentication"},{"text":" view modifier. It presents a browser-based OAuth flow and returns the result.","type":"text"}]},{"type":"codeListing","code":["import SwiftUI","import TMDBSwiftUI","","struct SettingsView: View {","    @State private var showAuth = false","","    var body: some View {","        Button(\"Sign In with TMDB\") {","            showAuth = true","        }","        .tmdbAuthentication(isPresented: $showAuth) { result in","            switch result {","            case .success(let session):","                print(\"Authenticated: \\(session.accountID)\")","            case .failure(let error):","                print(\"Auth failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"UIKit","level":2,"text":"UIKit"},{"type":"paragraph","inlineContent":[{"text":"Import ","type":"text"},{"type":"codeVoice","code":"TMDBUIKit"},{"text":" and call ","type":"text"},{"type":"codeVoice","code":"TMDB.authenticate(presentationAnchor:)"},{"text":" from a view controller.","type":"text"}]},{"type":"codeListing","code":["import UIKit","import TMDBUIKit","","class SettingsViewController: UIViewController {","    @IBAction func signInTapped(_ sender: Any) {","        Task {","            do {","                let session = try await TMDB.authenticate(","                    presentationAnchor: view.window!","                )","                print(\"Authenticated: \\(session.accountID)\")","            } catch {","                print(\"Auth failed: \\(error)\")","            }","        }","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Manual-Flow","level":2,"text":"Manual Flow"},{"type":"paragraph","inlineContent":[{"text":"For custom UIs, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/AuthenticationCoordinator"},{"text":" directly. This gives you control over each step of the OAuth flow.","type":"text"}]},{"type":"codeListing","code":["let coordinator = TMDB.AuthenticationCoordinator()","","\/\/ Step 1: Create a request token and get the approval URL","let (requestToken, approvalURL) = try await coordinator.createRequestToken()","","\/\/ Step 2: Open approvalURL in a browser for the user to approve","\/\/ When the browser redirects back to your app with a URL...","","\/\/ Step 3: Complete authentication with the redirect URL","let session = try await coordinator.authenticate(browserRedirectURL: redirectURL)","print(\"Access token: \\(session.accessToken)\")","print(\"Account ID: \\(session.accountID)\")"],"syntax":"swift"},{"type":"heading","anchor":"Logout","level":2,"text":"Logout"},{"type":"codeListing","code":["try await TMDB.logout()"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"This deletes the v4 access token, v3 session, and clears the keychain."}],"type":"paragraph"},{"anchor":"Checking-Auth-State","text":"Checking Auth State","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/isAuthenticated","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/currentSession","isActive":true},{"type":"text","text":" to check the current state:"}],"type":"paragraph"},{"code":["if TMDB.isAuthenticated {","    let session = TMDB.currentSession","    print(\"Logged in as \\(session?.accountID ?? \"\")\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/TMDB\/AuthSession","isActive":true},{"type":"text","text":" struct provides the authenticated user’s credentials:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Property","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessToken"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String"}]}],[{"type":"paragraph","inlineContent":[{"text":"v4 API access token","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accountID"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String"}]}],[{"type":"paragraph","inlineContent":[{"text":"TMDB account identifier","type":"text"}]}]],[[{"t