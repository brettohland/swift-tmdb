{"kind":"article","abstract":[{"text":"Use automatic mock data in unit tests and SwiftUI previews with zero configuration.","type":"text"}],"metadata":{"roleHeading":"Article","role":"article","title":"Testing and Previews","modules":[{"name":"TMDB"}]},"seeAlsoSections":[{"anchor":"Getting-Started","identifiers":["doc:\/\/TMDB\/documentation\/TMDB\/Usage","doc:\/\/TMDB\/documentation\/TMDB\/AuthenticationGuide","doc:\/\/TMDB\/documentation\/TMDB\/ErrorHandling","doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists","doc:\/\/TMDB\/documentation\/TMDB\/DiscoverFilters","doc:\/\/TMDB\/documentation\/TMDB\/TMDB","doc:\/\/TMDB\/documentation\/TMDB\/TMDBConfiguration"],"title":"Getting Started","generated":true}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"swift-tmdb"},{"text":" provides mock data automatically in test and preview contexts using ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","isActive":true},{"text":". No setup or registration is needed — just call TMDB methods as normal.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Unit Test Example","anchor":"Unit-Test-Example","type":"heading"},{"inlineContent":[{"text":"Tests can call any TMDB method directly. Mock data is returned instantly.","type":"text"}],"type":"paragraph"},{"code":["import Testing","@testable import TMDB","","struct MovieTests {","    @Test func movieDetailsReturnsValidData() async throws {","        let movie = try await TMDB.movieDetails(id: 550)","        #expect(movie.title == \"Fight Club\")","        #expect(movie.id == 550)","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Using MockableResponse","anchor":"Using-MockableResponse","type":"heading"},{"inlineContent":[{"text":"For direct access to mock models without making an API call, import ","type":"text"},{"type":"codeVoice","code":"TMDBMocking"},{"text":" and use the ","type":"text"},{"type":"codeVoice","code":"mock()"},{"text":" convenience method.","type":"text"}],"type":"paragraph"},{"code":["import Testing","import TMDB","import TMDBMocking","","struct ModelTests {","    @Test func movieMockHasExpectedValues() {","        let movie = TMDB.Movie.mock()","        #expect(!movie.title.isEmpty)","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"SwiftUI Previews","anchor":"SwiftUI-Previews","type":"heading"},{"inlineContent":[{"text":"Previews work identically to production code. Mock data is returned automatically with a 2-second delay to simulate realistic loading.","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import TMDB","","#Preview {","    MovieListView()","}","","struct MovieListView: View {","    @State private var movies: [TMDB.Discover.DiscoverMovie] = []","","    var body: some View {","        List(movies, id: \\.id) { movie in","            Text(movie.title)","        }","        .task {","            let results = try? await TMDB.searchMovies(query: \"Matrix\")","            movies = results?.results ?? []","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Dependency Overrides","anchor":"Dependency-Overrides","type":"heading"},{"inlineContent":[{"text":"For custom test doubles, use ","type":"text"},{"type":"codeVoice","code":"withDependencies"},{"text":" to override the HTTP client or other internals.","type":"text"}],"type":"paragraph"},{"code":["import Testing","import Dependencies","@testable import TMDB","","struct CustomMockTests {","    @Test func customOverride() async throws {","        try await withDependencies {","            $0.httpClient = .init(","                data: { _ in","                    \/\/ Return custom mock data","                    (customJSON, HTTPURLResponse())","                }","            )","        } operation: {","            let movie = try await TMDB.movieDetails(id: 1)","            #expect(movie.title == \"Custom Title\")","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"identifier":{"url":"doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/tmdb\/testingandpreviews"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://TMDB/documentation/TMDB":{"abstract":[{"type":"text","text":"A Swift 6.2 wrapper around the TMDB API. Engineered for simplicity."}],"role":"collection","kind":"symbol","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB","title":"TMDB","url":"\/documentation\/tmdb"},"doc://TMDB/documentation/TMDB/Usage":{"role":"article","type":"topic","kind":"article","abstract":[{"text":"Instructions on initialization and usage of the ","type":"text"},{"type":"codeVoice","code":"swift-tmdb"},{"text":" package.","type":"text"}],"identifier":"doc:\/\/TMDB\/documentation\/TMDB\/Usage","title":"Usage","url":"\/documentation\/tmdb\/usage"},"doc://TMDB/documentation/TMDB/AccountAndLists":{"kind":"article","url":"\/documentation\/tmdb\/accountandlists","abstract":[{"text":"Manage favorites, watchlists, ratings, and custom lists for authenticated users.","type":"text"}],"title":"Account and Lists","role":"article","type":"topic","identifier":"doc:\/\/TMDB\/documentation\/TMDB\/AccountAndLists"},"https://github.com/pointfreeco/swift-dependencies":{"type":"link","titleInlineContent":[{"text":"PointFree’s Dependencies","type":"text"}],"url":"https:\/\/github.com\/pointfreeco\/swift-dependencies","identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies","title":"PointFree’s Dependencies"},"doc://TMDB/documentation/TMDB/AuthenticationGuide":{"kind":"article","url":"\/documentation\/tmdb\/authenticationguide","abstract":[{"text":"Authenticate users with TMDB to enable account features, lis