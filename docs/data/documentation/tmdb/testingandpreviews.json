{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Use automatic mock data in unit tests and SwiftUI previews with zero configuration."}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/TMDB\/documentation\/TMDB\/TestingAndPreviews"},"hierarchy":{"paths":[["doc:\/\/TMDB\/documentation\/TMDB"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"code":"swift-tmdb","type":"codeVoice"},{"text":" provides mock data automatically in test and preview contexts using ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/pointfreeco\/swift-dependencies"},{"type":"text","text":". No setup or registration is needed — just call TMDB methods as normal."}]},{"anchor":"Unit-Test-Example","text":"Unit Test Example","type":"heading","level":2},{"inlineContent":[{"text":"Tests can call any TMDB method directly. Mock data is returned instantly.","type":"text"}],"type":"paragraph"},{"code":["import Testing","@testable import TMDB","","struct MovieTests {","    @Test func movieDetailsReturnsValidData() async throws {","        let movie = try await TMDB.movieDetails(id: 550)","        #expect(movie.title == \"Fight Club\")","        #expect(movie.id == 550)","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Using-MockableResponse","text":"Using MockableResponse","level":2,"type":"heading"},{"inlineContent":[{"text":"For direct access to mock models without making an API call, import ","type":"text"},{"code":"TMDBMocking","type":"codeVoice"},{"text":" and use the ","type":"text"},{"code":"mock()","type":"codeVoice"},{"text":" convenience method.","type":"text"}],"type":"paragraph"},{"code":["import Testing","import TMDB","import TMDBMocking","","struct ModelTests {","    @Test func movieMockHasExpectedValues() {","        let movie = TMDB.Movie.mock()","        #expect(!movie.title.isEmpty)","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"SwiftUI-Previews","text":"SwiftUI Previews","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Previews work identically to production code. Mock data is returned automatically with a 2-second delay to simulate realistic loading."}],"type":"paragraph"},{"code":["import SwiftUI","import TMDB","","#Preview {","    MovieListView()","}","","struct MovieListView: View {","    @State private var movies: [TMDB.Discover.DiscoverMovie] = []","","    var body: some View {","        List(movies, id: \\.id) { movie in","            Text(movie.title)","        }","        .task {","            let results = try? await TMDB.searchMovies(query: \"Matrix\")","            movies = results?.results ?? []","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Dependency-Overrides","text":"Dependency Overrides","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For custom test doubles, use "},{"code":"withDependencies","type":"codeVoice"},{"text":" to override the HTTP client or other internals.","type":"text"}],"type":"paragraph"},{"code":["import Testing","import Dependencies","@testable import TMDB","","struct CustomMockTests {","    @Test func customOverride() async throws {","        try await withDependencies {","            $0.httpClient = .init(","                data: { _ in","                    \/\/ Return custom mock data","                    (customJSON, HTTPURLResponse())","                }","            )","        } operation: {","            let movie = try await TMDB.movieDetails(id: 1)","            #expect(movie.title == \"Custom Title\")","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/tmdb\/testingandpreviews"]}],"sections":[],"metadata":{"role":"article","roleHeading":"Article","title":"Testing and Previews","modules":[{"name":